# Files Claude Code agents must skip when building context (gitignore-style patterns)

# Dependencies & build output
node_modules/
.venv/
dist/
build/
.next/
coverage/
*.egg-info/

# Python bytecode & tool caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Cursor / Claude runtime caches
.cursor/cache/
.cursor/logs/

# Generated knowledge graph (use `graphify query`, not raw cache files)
graphify-out/

# Runtime logs & mutable data snapshots
logs/
*.log

# Secrets
.env
.env.*

# Large binaries & media
*.zip
*.tar.gz
*.png
*.jpg
*.jpeg
*.gif
*.webp
*.pdf

# OS junk
.DS_Store
Thumbs.db
