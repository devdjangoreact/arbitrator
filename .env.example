# Copy this file to .env and edit values as needed.
# .env is gitignored. .env.example is committed.

# --- Markets (USDT-M perpetual futures only) ---
# JSON list of ccxt unified symbols, settled in USDT
SYMBOLS=["BTC/USDT:USDT","SOL/USDT:USDT","BNB/USDT:USDT","ETH/USDT:USDT"]
# Which exchanges to subscribe to (must match ExchangeFactory registry)
ENABLED_EXCHANGES=["binance","mexc","bitget","gate","bingx"]
# ccxt defaultType. Stay on "swap" — this project is futures-only.
DEFAULT_TYPE=swap

# --- Networking ---
# Use aiohttp.ThreadedResolver instead of aiodns (fixes "Could not contact DNS servers")
USE_THREADED_DNS_RESOLVER=true
AIOHTTP_TRUST_ENV=true
ENABLE_RATE_LIMIT=true

# --- UI ---
STREAMLIT_PAGE_TITLE=Arbitrator
STREAMLIT_PAGE_LAYOUT=wide

# --- Logging ---
LOG_LEVEL=INFO

WATCH_TICKERS_CHUNK_SIZE=50
WS_RECONNECT_DELAY_SECONDS=5.0

WATCH_TICKERS_MAX_CONCURRENT_CHUNKS=3
CCXT_REQUEST_TIMEOUT_MS=60000

# --- Screener ---
DEFAULT_MIN_QUOTE_VOLUME_KUSDT=0
STREAM_MIN_QUOTE_VOLUME_USDT=50000
DEFAULT_MIN_SPREAD_PCT=0.0
SCREENER_VOLUME_DISCOVERY_SECONDS=30.0

# --- Exchange API credentials (USDT-M futures) ---
# Leave empty for exchanges you do not trade on.
BINANCE_API_KEY=
BINANCE_API_SECRET=
MEXC_API_KEY=
MEXC_API_SECRET=
BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=
GATE_API_KEY=
GATE_API_SECRET=
BINGX_API_KEY=
BINGX_API_SECRET=

# Arbitrage (USDT-M futures pairs)
ARB_OPEN_SPREAD_THRESHOLD_PCT=4.0
ARB_CLOSE_SPREAD_THRESHOLD_PCT=0.1
ARB_AUTO_OPEN_ENABLED=false
ARB_AUTO_CLOSE_ENABLED=false
ARB_DEFAULT_NOTIONAL_USDT=100
ARB_PAIRING_WINDOW_SECONDS=300
ARB_CLOSED_HISTORY_DAYS=30
ARB_POSITIONS_POLL_SECONDS=5

OPPORTUNITY_ORDER_BOOK_DEPTH=20
OPPORTUNITY_CHART_WINDOW_SECONDS=1800
OPPORTUNITY_POLL_SECONDS=1
OPP_DEFAULT_ACCUMULATE_SPREAD_PCT=4.0
OPP_DEFAULT_MAX_NOTIONAL_USDT=500
OPP_DEFAULT_LEVERAGE=10
OPP_POSITION_IMBALANCE_TOLERANCE_PCT=1.0
OPP_ACCUMULATE_STEP_USDT=100

# UI mock/live mode
UI_DATA_MODE=mock_data
MOCK_TICK_SECONDS=1.0
SCREENER_WS_PUSH_SECONDS=1.0

# --- Strategy engine (002-strategy-engine) ---
# Spot data/execution channel (basis & funding+spot-hedge strategies)
SPOT_ENABLED=false
SPOT_DEFAULT_TYPE=spot
# Max age (seconds) before cached market data is treated as stale -> strategy N/A
QUOTE_MAX_AGE_SECONDS=5.0
BOOK_MAX_AGE_SECONDS=2.0
# Funding rate REST refresh cadence and pre-settlement entry window
FUNDING_REFRESH_SECONDS=60.0
FUNDING_ENTRY_WINDOW_SECONDS=300.0
# Output rounding (UI edge only); domain keeps full Decimal precision
STRATEGY_DECIMAL_PLACES=2
# Anomaly guard: spread above this percent blocks auto-entry (possible listing/withdraw)
ANOMALY_MAX_SPREAD_PCT=20.0
SLIPPAGE_MAX_PCT=0.5
# Advisory prediction score (never blocks core calc)
PREDICTION_ENABLED=false
PREDICTION_WINDOW_SECONDS=120.0
# Deposit basis for "% to deposit": position_margin = sum(notional_leg/leverage_leg), spot leg 1x
DEPOSIT_BASIS=position_margin
# Hedged execution: roll back the filled leg if the opposite leg fails
EXECUTION_ROLLBACK_ENABLED=true
# Allowed residual leg imbalance after partial close (percent)
LEG_IMBALANCE_TOLERANCE_PCT=1.0
