# Copy this file to .env and fill in your values.
# .env is gitignored. This file is committed as documentation.

# =============================================================================
# MODE
# =============================================================================
# Режим роботи застосунку.
# Можливі значення:
#   mock_data  — UI з генерованими даними, без підключення до бірж
#   live       — реальні WebSocket потоки, реальні ордери
#   paper      — реальні потоки даних, симульовані ордери (paper_orders.json)
UI_DATA_MODE=mock_data

# Інтервал оновлення mock-даних (секунди). Діє тільки при UI_DATA_MODE=mock_data
MOCK_TICK_SECONDS=1.0


# =============================================================================
# EXCHANGES
# =============================================================================
# JSON-масив ID бірж які підключаються.
# Можливі значення: "mexc", "bitget", "gate", "bingx", "binance"
# Приклад: ["mexc","bitget","gate","bingx"]
# Примітка: для live/paper режиму потрібні API ключі для кожної активної біржі
ENABLED_EXCHANGES=["mexc","bitget","gate","bingx"]

# --- API ключі (обовʼязково для live/paper режиму) ---
MEXC_API_KEY=
MEXC_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=

GATE_API_KEY=
GATE_API_SECRET=

BINGX_API_KEY=
BINGX_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=


# =============================================================================
# TELEGRAM NOTIFICATIONS
# =============================================================================
# Токен бота — отримати у @BotFather
TELEGRAM_BOT_TOKEN=
# ID чату — отримати у @userinfobot або через /getUpdates
TELEGRAM_CHAT_ID=


# =============================================================================
# SERVER
# =============================================================================
# IP адреса на якій слухає FastAPI. 127.0.0.1 = тільки локально, 0.0.0.0 = всі інтерфейси
FASTAPI_HOST=127.0.0.1
# TCP порт
FASTAPI_PORT=8000
# Авто-перезапуск при зміні файлів. true тільки для розробки, false для продакшну
FASTAPI_RELOAD=false
# Назва застосунку в заголовку UI
APP_TITLE=Arbitrator


# =============================================================================
# LOGGING
# =============================================================================
# Рівень логування. Можливі значення (від найдетальнішого до найтихішого):
#   TRACE    — все, включаючи внутрішні ccxt дзвінки
#   DEBUG    — діагностичні повідомлення
#   INFO     — основні події (старт/стоп, відкриття/закриття позицій)
#   WARNING  — попередження, не критичні помилки
#   ERROR    — тільки помилки
LOG_LEVEL=INFO


# =============================================================================
# NETWORKING / CCXT
# =============================================================================
# Використовувати aiohttp.ThreadedResolver (усуває проблеми з DNS на Windows)
# true | false
USE_THREADED_DNS_RESOLVER=true

# Враховувати змінні HTTP_PROXY / HTTPS_PROXY з оточення
# true | false
AIOHTTP_TRUST_ENV=true

# Вбудований rate limiter ccxt (запобігає бану IP)
# true | false — рекомендовано true
ENABLE_RATE_LIMIT=true

# Таймаут одного REST запиту до біржі (мілісекунди)
CCXT_REQUEST_TIMEOUT_MS=60000

# Затримка перед повторним підключенням WebSocket після обриву (секунди)
WS_RECONNECT_DELAY_SECONDS=5.0

# Кількість символів в одному WebSocket chunk (watch_tickers)
WATCH_TICKERS_CHUNK_SIZE=50

# Максимум паралельних WebSocket chunks на одну біржу
WATCH_TICKERS_MAX_CONCURRENT_CHUNKS=8


# =============================================================================
# SCREENER
# =============================================================================
# Мінімальний 24h обʼєм торгів для потокової передачі символу (USDT)
# Символи нижче порогу не завантажуються в WebSocket — зменшує навантаження
STREAM_MIN_QUOTE_VOLUME_USDT=500000.0

# Фільтр скрінера за замовчуванням: мін обʼєм в UI (тисячі USDT, 0 = без фільтру)
DEFAULT_MIN_QUOTE_VOLUME_KUSDT=500.0

# Фільтр скрінера за замовчуванням: мін спред в UI (%, 0 = без фільтру)
DEFAULT_MIN_SPREAD_PCT=0.0

# Символ повинен бути присутній мінімум на N активних біржах
MIN_EXCHANGES_PER_SYMBOL=2

# TTL кешу всесвіту символів (години). Після закінчення — перезавантаження з бірж
UNIVERSE_TTL_HOURS=24

# Інтервал відправки оновлень скрінера браузеру через WebSocket (секунди)
SCREENER_WS_PUSH_SECONDS=1.0

# Як часто перевіряти обʼєм торгів для виявлення нових символів (секунди)
SCREENER_VOLUME_DISCOVERY_SECONDS=60.0

# Висота таблиці скрінера в UI (пікселі)
SCREENER_TABLE_HEIGHT_PX=800


# =============================================================================
# OPPORTUNITY VIEW
# =============================================================================
# Глибина стакану замовлень на кожну сторону (bid/ask рівнів)
OPPORTUNITY_ORDER_BOOK_DEPTH=20

# Ширина вікна графіку цін (секунди)
OPPORTUNITY_CHART_WINDOW_SECONDS=120

# Інтервал оновлення сторінки Opportunity (секунди)
OPPORTUNITY_POLL_SECONDS=1

# Максимальний номінал на одну пару в Opportunity UI (USDT)
OPP_DEFAULT_MAX_NOTIONAL_USDT=500.0

# Плече для обох ніг за замовчуванням
OPP_DEFAULT_LEVERAGE=10

# Крок добору при кожному кліку «Accumulate» (USDT)
OPP_ACCUMULATE_STEP_USDT=100.0

# Допустимий дисбаланс між ногами (%). Вище — статус partial
OPP_POSITION_IMBALANCE_TOLERANCE_PCT=1.0

# Спред відкриття попередньо заповнений в полі UI (%)
OPP_DEFAULT_ACCUMULATE_SPREAD_PCT=4.0

# Поріг відкриття для кнопки «Авто добір» в Opportunity (%)
ARB_OPEN_SPREAD_THRESHOLD_PCT=4.0

# Поріг закриття для кнопки «Авто скидання» в Opportunity (%)
ARB_CLOSE_SPREAD_THRESHOLD_PCT=0.1

# Стан галочки «Авто добір» за замовчуванням
# true | false
ARB_AUTO_OPEN_ENABLED=false

# Інтервал перевірки авто-відкриття в Opportunity (секунди)
ARB_AUTO_OPEN_CHECK_SECONDS=30

# Стан галочки «Авто скидання» за замовчуванням
# true | false
ARB_AUTO_CLOSE_ENABLED=false

# Номінал для розрахунку прибутковості стратегій у скрінері (USDT). 0 = не показувати
ARB_DEFAULT_NOTIONAL_USDT=100.0

# Вікно часу для парування ніг позиції (секунди)
ARB_PAIRING_WINDOW_SECONDS=300

# Скільки днів зберігати закриті позиції в UI (дні)
ARB_CLOSED_HISTORY_DAYS=30

# Інтервал опитування позицій в Opportunity (секунди)
ARB_POSITIONS_POLL_SECONDS=5


# =============================================================================
# STRATEGY ENGINE
# =============================================================================
# Максимальний вік котирування після якого воно вважається застарілим (секунди)
QUOTE_MAX_AGE_SECONDS=5.0

# Максимальний вік стакану замовлень (секунди)
BOOK_MAX_AGE_SECONDS=2.0

# Як часто оновлювати ставки фандінгу через REST (секунди)
FUNDING_REFRESH_SECONDS=60.0

# Вікно входу у фандінгову стратегію — скільки секунд до розрахунку дозволено відкривати
FUNDING_ENTRY_WINDOW_SECONDS=300.0

# Увімкнути спотові стратегії (futures_spot_2ex, futures_spot_1ex, funding_fs)
# true | false — вимагає API ключів з дозволом на торгівлю на споті
SPOT_ENABLED=false

# Тип ринку для спотових запитів (не змінювати)
# Можливі значення: spot
SPOT_DEFAULT_TYPE=spot

# База для розрахунку % прибутковості:
# Можливі значення:
#   position_margin   — маржа позиції (показує прибутковість на вкладену маржу)
#   account_balance   — весь баланс акаунту
DEPOSIT_BASIS=position_margin

# Аномальний спред — відхиляти відкриття якщо спред перевищує (%)
# Захист від різних токенів з однаковим символом на різних біржах
ANOMALY_MAX_SPREAD_PCT=20.0

# Розрахункове максимальне проковзування на одну ногу (%). Враховується в net PnL
SLIPPAGE_MAX_PCT=0.5

# Відхиляти тікери з власним bid-ask спредом вище (%). Фільтр неліквідних ринків
TICKER_MAX_INNER_SPREAD_PCT=1.0

# Кількість знаків після коми у вихідних значеннях стратегій
STRATEGY_DECIMAL_PLACES=2

# Відкотити відкриту ногу якщо друга нога не виконалась
# true | false — рекомендовано true (без відкату залишається нехеджована позиція)
EXECUTION_ROLLBACK_ENABLED=true

# Допустимий дисбаланс між ногами після виконання (%). Вище — статус partial
LEG_IMBALANCE_TOLERANCE_PCT=1.0

# Кулдаун після невдалого відкриття перед повторною спробою тієї ж пари (секунди)
OPEN_FAIL_COOLDOWN_SEC=120.0

# Експериментальне прогнозування спреду (тримати false у продакшні)
# true | false
PREDICTION_ENABLED=false

# Ширина вікна для прогнозування (секунди). Діє тільки при PREDICTION_ENABLED=true
PREDICTION_WINDOW_SECONDS=120.0


# =============================================================================
# STRATEGY SELECTION & PER-STRATEGY OVERRIDES
# =============================================================================
# Вайтліст стратегій які дозволено відкривати авто-трейдеру.
# Порожній список [] = всі 6 стратегій дозволені.
# Можливі значення елементів:
#   futures_futures      — §3: шорт ф'ючерс / лонг ф'ючерс (різні біржі)
#   futures_spot_2ex     — §2: шорт ф'ючерс (біржа A) / лонг спот (біржа B)
#   futures_spot_1ex     — §1: шорт ф'ючерс / лонг спот (одна і та сама біржа)
#   funding_ff           — §4: обидві ноги ф'ючерс, тримати до фандінгу
#   funding_fs           — §6/§7: шорт ф'ючерс / лонг спот, тримати до фандінгу
#   funding_diff_dates   — §5: різні дати розрахунку фандінгу між біржами
#
# Приклади:
#   Тільки фандінгові стратегії:
#     ALLOWED_STRATEGIES=["funding_ff","funding_fs","funding_diff_dates"]
#   Тільки звичайний арбітраж:
#     ALLOWED_STRATEGIES=["futures_futures","futures_spot_2ex","futures_spot_1ex"]
#   Одна стратегія:
#     ALLOWED_STRATEGIES=["futures_futures"]
ALLOWED_STRATEGIES=[]

# Індивідуальні параметри для кожної стратегії (JSON dict).
# Якщо параметр не вказано — використовується глобальний дефолт з секції AUTO-TRADER нижче.
#
# Можливі ключі в dict кожної стратегії:
#   open_spread_pct   (число) — поріг спреду для входу, %
#   close_spread_pct  (число) — поріг спреду для виходу, %
#   notional_usdt     (число) — розмір позиції, USDT
#   max_positions     (число) — максимум одночасних позицій
#
# Правило вибору значення:
#   ефективне = STRATEGY_OVERRIDES[strategy_id][param]  (якщо задано)
#            ?? SCREENER_AUTO_TRADE_*  (глобальний дефолт нижче)
#
# Приклади:
#   Дефолт 2%, futures_futures — 1.5%:
#     SCREENER_AUTO_TRADE_OPEN_SPREAD_PCT=2.0
#     STRATEGY_OVERRIDES={"futures_futures": {"open_spread_pct": 1.5}}
#
#   funding_ff з маленьким порогом закриття і більшим номіналом:
#     STRATEGY_OVERRIDES={"funding_ff": {"open_spread_pct": 0.8, "close_spread_pct": 0.01, "notional_usdt": 200}}
#
#   Кілька стратегій одночасно:
#     STRATEGY_OVERRIDES={"futures_futures": {"open_spread_pct": 1.5}, "funding_ff": {"open_spread_pct": 0.8}, "funding_fs": {"notional_usdt": 500, "max_positions": 2}}
STRATEGY_OVERRIDES={}


# =============================================================================
# PAPER TRADING
# =============================================================================
# Шлях до JSON файлу де зберігаються симульовані ордери
PAPER_ORDERS_PATH=src/arbitrator/data/paper_orders.json


# =============================================================================
# AUTO-TRADER — GLOBAL DEFAULTS
# Застосовуються до всіх стратегій якщо не перевизначено в STRATEGY_OVERRIDES.
# =============================================================================
# Увімкнути фоновий авто-трейдер скрінера (тільки paper mode)
# true | false
SCREENER_AUTO_TRADE_ENABLED=false

# Увімкнути live авто-трейдер (тільки live mode — РЕАЛЬНІ ГРОШІ)
# true | false
# УВАГА: відкриває реальні позиції на біржах. Використовувати обережно.
LIVE_AUTO_TRADE_ENABLED=false

# Максимальна кількість одночасно відкритих пар (по всіх стратегіях разом)
SCREENER_AUTO_TRADE_MAX_POSITIONS=3

# Мінімальний номінал на одну пару (USDT). Реальний = max(мінімум біржі, це значення)
# 0 = завжди використовувати мінімум біржі
SCREENER_AUTO_TRADE_NOTIONAL_USDT=100.0

# Відкрити коли (short_bid - long_ask) / long_ask >= (%)
SCREENER_AUTO_TRADE_OPEN_SPREAD_PCT=3.0

# Закрити коли (short_ask - long_bid) / long_bid <= (%)
SCREENER_AUTO_TRADE_CLOSE_SPREAD_PCT=0.05

# Як часто сканувати скрінер (секунди)
SCREENER_AUTO_TRADE_CHECK_SECONDS=2.0

# Примусово закрити незахеджовану ногу після цього часу (секунди). Має бути > check_seconds
SCREENER_AUTO_TRADE_UNHEDGED_TIMEOUT_SECONDS=10.0

# Post-fill guard: закрити пару одразу якщо реальний спред після заповнення < (%)
LIVE_AUTO_TRADE_POST_FILL_MIN_SPREAD_PCT=0.5

# DCA: донабирати коли поточний спред >= entry_spread + (%)
LIVE_AUTO_TRADE_DCA_SPREAD_STEP_PCT=1.0

# DCA: максимальна кількість доборів на одну пару
LIVE_AUTO_TRADE_DCA_MAX_LAYERS=1

# DCA: мінімальна відстань до ліквідації (%) необхідна для допуску донабору
LIVE_AUTO_TRADE_DCA_MIN_LIQ_DISTANCE_PCT=10.0

# DCA: не набирати якщо наступний фандінг настане менш ніж через (секунди)
LIVE_AUTO_TRADE_DCA_FUNDING_SKIP_SECONDS=1800.0


# =============================================================================
# LIVE LIQUIDATION GUARD  (тільки live mode)
# =============================================================================
# Автоматично закривати позиції при наближенні до ціни ліквідації
# true | false
LIVE_LIQ_GUARD_ENABLED=true

# Як часто перевіряти позиції (секунди)
LIVE_LIQ_GUARD_CHECK_INTERVAL_SECONDS=5.0

# Закрити коли використано N% від дистанції маржа→ліквідація (0-100)
# 80 = закрити коли залишилось 20% до ліквідації
LIVE_LIQ_GUARD_WARNING_PCT_TO_LIQ=80.0


# =============================================================================
# LIVE FUNDING PROTECTION  (тільки live mode)
# =============================================================================
# Автоматично закрити+перевідкрити якщо вартість фандінгу перевищує round-trip комісії
# true | false
LIVE_FUNDING_PROTECT_ENABLED=false

# Як часто перевіряти (секунди)
LIVE_FUNDING_PROTECT_CHECK_INTERVAL_SECONDS=30.0

# Починати діяти коли до розрахунку фандінгу залишилось менше (секунди)
LIVE_FUNDING_PROTECT_ACT_WINDOW_SECONDS=300.0

# Не діяти в останні N секунд перед фандінгом (уникати стрибків спреду)
LIVE_FUNDING_PROTECT_SKIP_WITHIN_SECONDS=60.0

# Мінімальний поточний спред (%) для перевідкриття після закриття
LIVE_FUNDING_PROTECT_MIN_REOPEN_SPREAD_PCT=0.1


# =============================================================================
# LIQUIDATION GUARD  (тільки paper mode)
# =============================================================================
# true | false
LIQ_GUARD_ENABLED=true
LIQ_GUARD_CHECK_INTERVAL_SECONDS=5.0
# Закрити коли використано N% від дистанції маржа→ліквідація (0-100)
LIQ_GUARD_WARNING_PCT_TO_LIQ=80.0


# =============================================================================
# FUNDING REENTRY  (тільки paper mode)
# =============================================================================
# Автоматично закрити+перевідкрити коли вартість фандінгу перевищує round-trip комісії
# true | false
FUNDING_REENTRY_ENABLED=false

# Як часто оцінювати позиції (секунди)
FUNDING_REENTRY_CHECK_INTERVAL_SECONDS=30.0

# Починати перевірку коли до фандінгу залишилось менше (секунди)
FUNDING_REENTRY_ACT_WINDOW_SECONDS=300.0

# Не діяти в останні N секунд перед фандінгом
FUNDING_REENTRY_SKIP_WITHIN_SECONDS=60.0

# Мінімальний спред (%) для перевідкриття
FUNDING_REENTRY_MIN_SPREAD_PCT=0.1
