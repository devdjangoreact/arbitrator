# Copy this file to .env and fill in your values.
# .env is gitignored. This file is committed as documentation.

# =============================================================================
# MODE
# =============================================================================
# mock_data — UI with generated data, no exchange connection
# live      — real WebSocket streams, real orders
# paper     — real streams, simulated orders written to paper_orders.json
UI_DATA_MODE=mock_data
MOCK_TICK_SECONDS=1.0


# =============================================================================
# EXCHANGES
# =============================================================================
# Comma-separated list of exchange IDs to enable.
# Supported: mexc, bitget, gate, bingx, binance
ENABLED_EXCHANGES=["mexc","bitget","gate","bingx"]

# --- API keys (required for live/paper mode) ---
MEXC_API_KEY=
MEXC_API_SECRET=

BITGET_API_KEY=
BITGET_API_SECRET=
BITGET_API_PASSWORD=

GATE_API_KEY=
GATE_API_SECRET=

BINGX_API_KEY=
BINGX_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=


# =============================================================================
# SERVER
# =============================================================================
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
# true only for local dev (auto-restart on file change)
FASTAPI_RELOAD=false
APP_TITLE=Arbitrator


# =============================================================================
# LOGGING
# =============================================================================
# TRACE | DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =============================================================================
# NETWORKING / CCXT
# =============================================================================
# Use aiohttp.ThreadedResolver (fixes DNS issues on Windows)
USE_THREADED_DNS_RESOLVER=true
# Honour HTTP(S)_PROXY env vars inside aiohttp
AIOHTTP_TRUST_ENV=true
# ccxt built-in rate limiter
ENABLE_RATE_LIMIT=true
# Per-request timeout in milliseconds
CCXT_REQUEST_TIMEOUT_MS=60000
# Symbols per WebSocket chunk
WATCH_TICKERS_CHUNK_SIZE=50
# Max concurrent WebSocket chunks per exchange
WATCH_TICKERS_MAX_CONCURRENT_CHUNKS=8


# =============================================================================
# SCREENER
# =============================================================================
# Minimum 24h quote volume to stream a symbol (USDT)
STREAM_MIN_QUOTE_VOLUME_USDT=50000.0
# Default screener filter: min volume shown in UI (k USDT, 0 = no filter)
DEFAULT_MIN_QUOTE_VOLUME_KUSDT=500.0
# Default screener filter: min spread shown in UI (%, 0 = no filter)
DEFAULT_MIN_SPREAD_PCT=0.0
# Symbols must be listed on at least this many enabled exchanges
MIN_EXCHANGES_PER_SYMBOL=2
# Symbol universe cache TTL (hours)
UNIVERSE_TTL_HOURS=24
# Push interval from server to browser (seconds)
SCREENER_WS_PUSH_SECONDS=1.0


# =============================================================================
# OPPORTUNITY VIEW
# =============================================================================
# Order book depth per side
OPPORTUNITY_ORDER_BOOK_DEPTH=20
# Price chart rolling window (seconds)
OPPORTUNITY_CHART_WINDOW_SECONDS=120
# Default max notional per pair (USDT)
OPP_DEFAULT_MAX_NOTIONAL_USDT=500.0
# Default leverage applied to both legs
OPP_DEFAULT_LEVERAGE=10
# Default step size for each accumulate click (USDT)
OPP_ACCUMULATE_STEP_USDT=100.0
# Tolerated imbalance between legs (%)
OPP_POSITION_IMBALANCE_TOLERANCE_PCT=1.0
# Spread pre-filled in the open-spread field (%)
OPP_DEFAULT_ACCUMULATE_SPREAD_PCT=4.0


# =============================================================================
# STRATEGY ENGINE
# =============================================================================
# Quote is considered stale after this many seconds
QUOTE_MAX_AGE_SECONDS=5.0
# Order book is considered stale after this many seconds
BOOK_MAX_AGE_SECONDS=2.0
# How often to refresh funding rates via REST (seconds)
FUNDING_REFRESH_SECONDS=60.0
# Only enter a funding trade within this window before settlement (seconds)
FUNDING_ENTRY_WINDOW_SECONDS=300.0
# Enable spot-leg strategies (futures-spot 2ex / 1ex)
SPOT_ENABLED=false
# Deposit basis for % return calculation: position_margin | account_balance
DEPOSIT_BASIS=position_margin
# Reject entries where spread exceeds this — anomaly guard (%)
ANOMALY_MAX_SPREAD_PCT=20.0
# Estimated worst-case slippage per leg (%)
SLIPPAGE_MAX_PCT=0.5
# Roll back the open leg if the second leg fails
EXECUTION_ROLLBACK_ENABLED=true
# Tolerated leg size imbalance before rollback (%)
LEG_IMBALANCE_TOLERANCE_PCT=1.0
# Default notional used in screener strategy calculations (USDT)
ARB_DEFAULT_NOTIONAL_USDT=100.0


# =============================================================================
# OPPORTUNITY AUTO-TRADE (per-symbol, controlled from UI checkboxes)
# =============================================================================
# Open spread threshold pre-filled in the UI (%)
ARB_OPEN_SPREAD_THRESHOLD_PCT=4.0
# Close spread threshold pre-filled in the UI (%)
ARB_CLOSE_SPREAD_THRESHOLD_PCT=0.1
# Default state of the "Авто добір" checkbox
ARB_AUTO_OPEN_ENABLED=false
# Default state of the "Авто скидання" checkbox
ARB_AUTO_CLOSE_ENABLED=false


# =============================================================================
# PAPER TRADING
# =============================================================================
# Where simulated orders are stored (JSON)
PAPER_ORDERS_PATH=src/arbitrator/data/paper_orders.json


# =============================================================================
# SCREENER AUTO-TRADER  (paper mode only)
# =============================================================================
# Enable the background worker that picks symbols from the screener and trades automatically
SCREENER_AUTO_TRADE_ENABLED=false
# Max simultaneous open pairs
SCREENER_AUTO_TRADE_MAX_POSITIONS=3
# Notional per pair (USDT)
SCREENER_AUTO_TRADE_NOTIONAL_USDT=100.0
# Open when (short_bid - long_ask) / long_ask >= this (%)
SCREENER_AUTO_TRADE_OPEN_SPREAD_PCT=0.3
# Close when (short_ask - long_bid) / long_bid <= this (%)
SCREENER_AUTO_TRADE_CLOSE_SPREAD_PCT=0.05
# How often to scan the screener (seconds).
# Tip: set to unhedged_timeout / 5 so an unhedged leg is checked ~5 times before forced close.
SCREENER_AUTO_TRADE_CHECK_SECONDS=2.0
# Close a single-leg (unhedged) position after this many seconds when its partner leg never opened.
# The leg is closed at market price. Must be > check_seconds.
# Example: 10s timeout with 2s check = 5 detection passes before forced close.
SCREENER_AUTO_TRADE_UNHEDGED_TIMEOUT_SECONDS=10.0


# =============================================================================
# LIQUIDATION GUARD  (paper mode only)
# =============================================================================
# Automatically close positions when approaching liquidation price
LIQ_GUARD_ENABLED=true
# How often to check positions (seconds)
LIQ_GUARD_CHECK_INTERVAL_SECONDS=5.0
# Close when this % of margin distance to liquidation is consumed (0-100)
LIQ_GUARD_WARNING_PCT_TO_LIQ=80.0


# =============================================================================
# FUNDING REENTRY  (paper mode only)
# =============================================================================
# Enable automatic close+reopen when funding cost exceeds round-trip fees
FUNDING_REENTRY_ENABLED=false
# How often to evaluate positions for potential reentry (seconds)
FUNDING_REENTRY_CHECK_INTERVAL_SECONDS=30.0
# Start evaluating reentry when the next funding settlement is within this many seconds.
# Default: 300 (5 minutes before funding). Increase to act earlier; decrease for tighter window.
FUNDING_REENTRY_ACT_WINDOW_SECONDS=300.0
# Stop acting when funding is closer than this many seconds away (avoid last-second spread spikes).
FUNDING_REENTRY_SKIP_WITHIN_SECONDS=60.0
# Minimum current spread (%) required to reopen after closing. Prevents reopening into a flat market.
FUNDING_REENTRY_MIN_SPREAD_PCT=0.1
