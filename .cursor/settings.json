{
  "$schema": "https://cursor.sh/schemas/project-settings.json",
  "model": {
    "default": "auto"
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(src/**)",
      "Shell(git status)",
      "Shell(git diff*)",
      "Shell(npm run *)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Edit(.env*)"
    ]
  },
  "hooks": ".cursor/hooks.json"
}
